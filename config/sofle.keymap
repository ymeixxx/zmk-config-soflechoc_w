#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/encoder.h>

/ {
    behaviors {
        mlt: dk_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <160>;
            quick-tap-ms = <220>;
            bindings = <&mo>, <&kp>;
            display-name = "MyLayer-Tap";
        };
    };

    macros {
        // 保留原有的宏定义...
    };

    encoders {
        compatible = "zmk,encoders";
        status = "okay";
        
        encoder_left: encoder_left {
            compatible = "alps,ec11";
            a-gpios = <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;  // P0.10
            b-gpios = <&gpio0 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   // P0.09
            steps = <15>;
            status = "okay";
        };

        encoder_right: encoder_right {
            compatible = "alps,ec11";
            a-gpios = <&gpio0 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   // P0.05
            b-gpios = <&gpio0 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   // P0.04
            steps = <15>;
            status = "okay";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                // 保持原有的键盘矩阵绑定...
            >;

            encoder_left: encoder_left {
                bindings = <&inc_dec_kp LEFT RIGHT>;  // 左旋钮控制左右方向键
            };
            encoder_right: encoder_right {
                bindings = <&inc_dec_kp UP DOWN>;     // 右旋钮控制上下方向键
            };
        };

        lower_layer {
            bindings = <
                // 保持原有的键盘矩阵绑定...
            >;

            encoder_left: encoder_left {
                bindings = <&inc_dec_kp LEFT RIGHT>;  // 保持一致的旋钮功能
            };
            encoder_right: encoder_right {
                bindings = <&inc_dec_kp UP DOWN>;
            };
        };

        raise_layer {
            bindings = <
                // 保持原有的键盘矩阵绑定...
            >;

            encoder_left: encoder_left {
                bindings = <&inc_dec_kp LEFT RIGHT>;  // 保持一致的旋钮功能
            };
            encoder_right: encoder_right {
                bindings = <&inc_dec_kp UP DOWN>;
            };
        };
    };
};
